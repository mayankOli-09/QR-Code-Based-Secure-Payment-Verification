# Rename this file to .env and fill in your API keys

# VirusTotal API Key (free tier available at https://www.virustotal.com)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Google Safe Browsing API Key (get from https://console.cloud.google.com)
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_key_here
